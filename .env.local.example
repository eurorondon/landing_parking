# ============================================================
# Variables de entorno — copiar a .env.local y rellenar
# ============================================================

# Clave de API de Resend (https://resend.com) para enviar el
# correo de cada reserva al dueño del parking.
# Sin esta clave la web funciona igual, pero el correo solo se
# muestra en la consola del servidor (modo desarrollo).
RESEND_API_KEY=

# Remitente del correo. El dominio debe estar verificado en Resend.
# Para pruebas puede usarse: onboarding@resend.dev
EMAIL_FROM="Parking Aéreo Madrid <reservas@tudominio.es>"

# ⚠️ CAMBIAR: contraseña de acceso al panel de administración (/admin).
# Si no se define, en desarrollo se usa "admin123".
ADMIN_PASSWORD=
