# ============================================================
# Variables de entorno — copiar a .env.local y rellenar
# ============================================================

# ── Base de datos MySQL (misma que parkingplus-dashboard) ───
# Las reservas de la web se guardan aquí con medio_reserva = 3.
# El panel del dashboard las verá junto al resto de reservas.
#
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_DB
DATABASE_URL=mysql://

# ── Correo de confirmación (SMTP / Nodemailer) ───────────────
# Se usa para enviar:
#   · Confirmación de reserva al cliente
#   · Aviso de nueva reserva al admin
#
# SMTP_HOST: servidor de correo saliente (IP o dominio del servidor)
#   Ejemplo Plesk/cPanel: mail.parkingaeromadrid.es  ó la IP del VPS
SMTP_HOST=mail.parkingaeromadrid.es
SMTP_PORT=465
SMTP_SECURE=true          # true = SSL en puerto 465 | false = STARTTLS en 587
SMTP_USER=reserva@parkingaeromadrid.es
SMTP_PASS=

# Remitente que verá el destinatario
MAIL_FROM="Parking Aero Madrid <reserva@parkingaeromadrid.es>"

# Correo que recibe la copia de cada reserva nueva (admin/dueño)
MAIL_ADMIN=parkingaeromadrid@gmail.com

# ── Panel de administración ──────────────────────────────────
# ⚠️ CAMBIAR: contraseña de acceso al panel /admin.
# Por defecto en desarrollo se usa "admin123".
ADMIN_PASSWORD=

# ── Notificaciones Discord ───────────────────────────────────
# Webhook de Discord para alertas de nuevas reservas.
# Cómo obtenerlo: canal Discord → Editar canal → Integraciones
#                 → Webhooks → Nuevo webhook → Copiar URL
# Si se deja vacío, las notificaciones simplemente no se envían.
DISCORD_WEBHOOK_URL=
