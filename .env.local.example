# ============================================================
# Variables de entorno — copiar a .env.local y rellenar
# ============================================================

# ── Base de datos MySQL (misma que parkingplus-dashboard) ───
# Las reservas de la web se guardan aquí con medio_reserva = 3.
# El panel del dashboard las verá junto al resto de reservas.
#
# Formato: mysql://USUARIO:CONTRASEÑA@HOST:PUERTO/NOMBRE_BD
DATABASE_URL=mysql://

# ── Correo de confirmación (Resend) ─────────────────────────
# Clave de API de Resend (https://resend.com).
# Sin esta clave la web funciona igual; el correo solo aparece
# en la consola del servidor (modo desarrollo).
RESEND_API_KEY=

# Remitente del correo (dominio verificado en Resend).
# Para pruebas: onboarding@resend.dev
EMAIL_FROM="Parking Aero Madrid <reservas@parkingaeromadrid.es>"

# ── Panel de administración ──────────────────────────────────
# ⚠️ CAMBIAR: contraseña de acceso al panel /admin.
# Por defecto en desarrollo se usa "admin123".
ADMIN_PASSWORD=
